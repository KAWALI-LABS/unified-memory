# ─── NEAR ───────────────────────────────────────────────
NEAR_CONTRACT_ID=consent-nft.testnet
NEAR_ACCOUNT_ID=your-account.testnet
NEAR_PRIVATE_KEY=ed25519:YOUR_PRIVATE_KEY

# ─── CIRCLE (x402 + Programmable Wallets) ────────────────
CIRCLE_API_KEY=your_circle_api_key
CIRCLE_WALLET_SET_ID=your_wallet_set_id
CIRCLE_AGENT_WALLET_ID=your_agent_wallet_id

# ─── PINECONE (Vector Memory Store) ─────────────────────
PINECONE_API_KEY=your_pinecone_key
PINECONE_INDEX_NAME=unified-memory
PINECONE_ENVIRONMENT=gcp-starter

# ─── OPENAI (Memory Synthesis + Demo Agent) ─────────────
OPENAI_API_KEY=your_openai_key

# ─── EAS (Base Sepolia Attestations) ────────────────────
EAS_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
EAS_SCHEMA_UID=0xYOUR_SCHEMA_UID
BASE_SEPOLIA_RPC=https://sepolia.base.org

# ─── CLOUDFLARE ──────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your_cf_account_id
CLOUDFLARE_API_TOKEN=your_cf_api_token

# ─── TAVILY (Memory Enrichment) ──────────────────────────
TAVILY_API_KEY=your_tavily_key

# ─── PLATFORM OAUTH CREDENTIALS ──────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
NOTION_API_KEY=your_notion_key
SLACK_BOT_TOKEN=xoxb-your-slack-token
DISCORD_BOT_TOKEN=your_discord_token
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
TELEGRAM_BOT_TOKEN=your_telegram_token

# ─── RAVI.ID (Agent Identity Proxy) ─────────────────────
RAVI_API_KEY=your_ravi_key
